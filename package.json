    "preview": "echo \"UI starts in Slice 2.\""
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "fast-check": "4.3.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}

