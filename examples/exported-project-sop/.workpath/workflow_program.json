      "title": "Worker handoff",
      "privacy": "internal",
      "kind": "handoff_packet",
      "task_id": "execute",
      "to": "codex-worker",
      "objective": "Implement the scoped slice without touching unrelated files.",
      "allowed_paths": [
        "src/**",
        "tests/**",
        "docs/**"
      ],
      "denied_paths": [
        ".env",
        ".ssh/**"
      ],
      "return_contract": {
