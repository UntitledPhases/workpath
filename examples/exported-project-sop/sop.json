{
  "schema_version": "1.0",
  "kind": "single_node_sop",
  "id": "sop_project_loop",
  "title": "Project SOP",
  "description": "Default loop for one AI work node.",
  "entry_node_id": "intent",
  "result_node_id": "return",
  "default_privacy": "internal",
  "nodes": [
    {
      "id": "intent",
      "title": "Extract intent",
      "privacy": "internal",
      "notes": "Clarify goal, constraints, done-state, and risk.",
      "kind": "step",
      "module": "intent"
    },
    {
      "id": "research",
      "title": "Research context",
      "privacy": "internal",
      "kind": "step",
      "module": "research"
    },
    {
      "id": "plan",
      "title": "Plan implementation",
      "privacy": "internal",
      "kind": "step",
      "module": "plan"
    },
    {
      "id": "execute",
      "title": "Execute work",
      "privacy": "internal",
      "kind": "step",
      "module": "execute"
    },
    {
      "id": "verify",
      "title": "Verify evidence",
      "privacy": "internal",
      "kind": "step",
      "module": "verify"
    },
    {
      "id": "return",
      "title": "Return result",
      "privacy": "internal",
      "kind": "step",
      "module": "return"
    },
    {
      "id": "gate_reverse_pass",
      "title": "Reverse pass complete",
      "privacy": "internal",
      "kind": "gate",
      "gate_kind": "reverse_pass",
      "task_id": "execute",
      "required_evidence": [
        "artifact_reverse_pass"
      ]
    },
    {
      "id": "gate_tests",
      "title": "Checks pass",
      "privacy": "internal",
      "kind": "gate",
      "gate_kind": "tests",
      "task_id": "verify",
      "required_evidence": [
        "artifact_tests_passed"
      ]
    },
    {
      "id": "artifact_reverse_pass",
      "title": "Reverse-pass notes",
      "privacy": "internal",
      "kind": "evidence",
      "artifact_kind": "review_note",
      "required": true
    },
    {
      "id": "artifact_tests_passed",
      "title": "Tests passed",
      "privacy": "internal",
      "kind": "evidence",
      "artifact_kind": "test_result",
      "required": true,
      "command": "npm test"
    },
    {
      "id": "boundary_codex_worker",
      "title": "Worker handoff",
      "privacy": "internal",
      "kind": "boundary",
      "task_id": "execute",
      "to": "codex-worker",
      "objective": "Implement the scoped slice without touching unrelated files.",
      "allowed_paths": [
        "src/**",
        "tests/**",
        "docs/**"
      ],
      "denied_paths": [
        ".env",
        ".ssh/**"
      ],
      "return_contract": {
        "required_fields": [
          "summary",
          "files_changed",
          "tests_run",
          "open_risks"
        ]
      },
      "evidence_required": [
        "artifact_tests_passed"
      ]
    }
  ],
  "edges": [
    {
      "id": "edge_intent_research",
      "from": "intent",
      "to": "research",
      "kind": "produces"
    },
    {
      "id": "edge_research_plan",
      "from": "research",
      "to": "plan",
      "kind": "produces"
    },
    {
